#compdef srl-sandbox
# Zsh tab-completion for srl-sandbox v2 (Apple Container)

_srl_sandbox_names() {
    local -a names
    local dir="$HOME/.config/srl-sandbox/sandboxes"
    if [[ -d "$dir" ]]; then
        names=("${(@f)$(ls "$dir"/*.json 2>/dev/null | xargs -I{} basename {} .json)}")
    fi
    _describe 'sandbox name' names
}

_srl_sandbox_names_or_all() {
    local -a completions
    completions=("all:All sandboxes")
    local dir="$HOME/.config/srl-sandbox/sandboxes"
    if [[ -d "$dir" ]]; then
        local f
        for f in "$dir"/*.json(N); do
            local name=$(basename "$f" .json)
            completions+=("$name:Sandbox $name")
        done
    fi
    _describe 'sandbox name' completions
}

_srl-sandbox() {
    local -a commands
    commands=(
        'launch:Create or resume sandbox for project directory'
        'stop:Stop a sandbox'
        'destroy:Delete container and state'
        'list:List all sandboxes with status'
        'ssh:Shell into running sandbox'
        'exec:Run command in sandbox'
        'sync:Re-sync settings and configs'
        'info:Show sandbox details'
        'build:Rebuild container image'
        'help:Show help text'
        'version:Show version'
    )

    if (( CURRENT == 2 )); then
        _describe 'command' commands
        return
    fi

    case "${words[2]}" in
        stop)
            if (( CURRENT == 3 )); then
                _srl_sandbox_names_or_all
            fi
            ;;
        destroy|ssh|sync|info)
            if (( CURRENT == 3 )); then
                _srl_sandbox_names
            fi
            ;;
        exec)
            if (( CURRENT == 3 )); then
                _srl_sandbox_names
            elif (( CURRENT >= 4 )); then
                _command_names
            fi
            ;;
        launch)
            _arguments \
                '--name[Override sandbox name]:name:' \
                '--cpus[CPU cores]:cores:(1 2 4 8)' \
                '--mem[RAM in GiB]:memory:(2 4 8 16 32)' \
                '*--mount[Mount extra directory (host\:guest)]:mount spec:' \
                '--no-sync[Skip settings sync]' \
                '--headless[Do not open terminal/editor]' \
                '*:project path:_directories'
            ;;
        build)
            ;;
    esac
}

_srl-sandbox "$@"
