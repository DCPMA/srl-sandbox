    printf "    ${CYAN}sync${NC} ${DIM}<name>${NC}             Re-sync settings, configs & extensions\n"
    printf "    ${CYAN}info${NC} ${DIM}<name>${NC}             Show sandbox details\n"
    echo ""
    printf "  ${BOLD}Launch Options${NC}\n"
    printf "    ${CYAN}--name${NC} ${DIM}<name>${NC}           Override auto-generated name\n"
