    printf "    ${DIM}\$${NC} srl-sandbox launch --cpus 4 --mem 8192 --headless\n"
    printf "    ${DIM}\$${NC} srl-sandbox list\n"
    printf "    ${DIM}\$${NC} srl-sandbox ssh srl-myapp-a1b2\n"
    printf "    ${DIM}\$${NC} srl-sandbox stop all\n"
    echo ""
}

# ── Ctrl+C Trap ──────────────────────────────────────────────────────────────

trap_handler() {
    echo ""
    warn "Interrupted. Note: any running VMs are still active."
    warn "Use 'srl-sandbox list' to see running sandboxes."
    exit 130
}
trap trap_handler INT

# ── Main ─────────────────────────────────────────────────────────────────────

main() {
    init_config

    # No arguments → launch sandbox for current directory
    [[ $# -eq 0 ]] && { check_parallels; cmd_launch; return; }

    local cmd="$1"; shift

    case "$cmd" in
        launch)    check_parallels; cmd_launch "$@" ;;
        stop)      check_parallels; cmd_stop "$@" ;;
        suspend)   check_parallels; cmd_suspend "$@" ;;
        destroy)   check_parallels; cmd_destroy "$@" ;;
        list)      check_parallels; cmd_list "$@" ;;
        ssh)       check_parallels; cmd_ssh "$@" ;;
        exec)      check_parallels; cmd_exec "$@" ;;
        provision) check_parallels; cmd_provision "$@" ;;
        sync)      check_parallels; cmd_sync "$@" ;;
        info)      check_parallels; cmd_info "$@" ;;
        help|--help|-h) cmd_help ;;
        version|--version|-v) echo "srl-sandbox v${VERSION}" ;;
        -*)        check_parallels; cmd_launch "$cmd" "$@" ;;
        *)         check_parallels; cmd_launch "$cmd" "$@" ;;
    esac
}

main "$@"
