    printf "    ${DIM}·${NC} VS Code settings.json, keybindings.json, snippets/\n"
    printf "    ${DIM}·${NC} VS Code extensions ${DIM}(installed in code-server)${NC}\n"
    echo ""
    printf "  ${BOLD}Examples${NC}\n"
    printf "    ${DIM}\$${NC} srl-sandbox provision --from \"Debian GNU Linux 12.11 ARM64\"\n"
