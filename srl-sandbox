#!/usr/bin/env zsh
# srl-sandbox v2 — Sandboxed development environments using Apple Container
# Spins up isolated Linux containers on macOS 26+ (Apple Silicon) for safe
# coding with LLM agents like Claude Code.
#
# Backend: Apple Container (github.com/apple/container)
# Each container = its own lightweight VM with sub-second startup.

set -euo pipefail

readonly VERSION="2.4.0"
readonly IMAGE_NAME="srl-sandbox"
readonly IMAGE_TAG="latest"
readonly IMAGE_REF="${IMAGE_NAME}:${IMAGE_TAG}"
readonly CONFIG_DIR="$HOME/.config/srl-sandbox"
readonly SANDBOXES_DIR="$CONFIG_DIR/sandboxes"
readonly CONFIG_FILE="$CONFIG_DIR/config.json"
readonly DEFAULT_CPUS=2
readonly DEFAULT_MEM=4
readonly DEFAULT_USER="dev"
readonly DNS_DOMAIN="test"
readonly SCRIPT_DIR="${0:A:h}"
readonly CONTAINERFILE="$SCRIPT_DIR/Containerfile"

# ── Colors ───────────────────────────────────────────────────────────────────
readonly RED=$'\033[0;31m'
readonly GREEN=$'\033[0;32m'
readonly YELLOW=$'\033[1;33m'
readonly BLUE=$'\033[0;34m'
readonly CYAN=$'\033[0;36m'
readonly MAGENTA=$'\033[0;35m'
readonly BOLD=$'\033[1m'
readonly DIM=$'\033[2m'
readonly NC=$'\033[0m'

# ── Helpers ──────────────────────────────────────────────────────────────────

msg()     { printf "${GREEN}  ▸${NC} %s\n" "$*" }
info()    { printf "${BLUE}  ℹ${NC} %s\n" "$*" }
warn()    { printf "${YELLOW}  ⚠${NC} %s\n" "$*" >&2 }
err()     { printf "${RED}  ✖${NC} %s\n" "$*" >&2 }
die()     { err "$@"; exit 1 }
bold()    { printf "${BOLD}%s${NC}" "$*" }
header()  { printf "\n${BOLD}${CYAN}━━ %s ━━${NC}\n" "$*" }
success() { printf "${GREEN}  ✔${NC} %s\n" "$*" }
step()    { printf "${DIM}  ·${NC} %s\n" "$*" }

spin() {
    local pid=$1 msg=$2
    local chars='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
    local i=0
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r${CYAN}%s${NC} %s" "${chars:$((i % ${#chars})):1}" "$msg"
        sleep 0.1
        i=$((i + 1))
    done
    printf "\r\033[K"
}

confirm() {
    local prompt="${1:-Are you sure?}"
    printf "${YELLOW}%s${NC} [y/N] " "$prompt"
    read -r reply
    [[ "$reply" =~ ^[Yy]$ ]]
}

confirm_default_yes() {
    local prompt="${1:-Continue?}"
    printf "${YELLOW}%s${NC} [Y/n] " "$prompt"
    read -r reply
    [[ -z "$reply" || "$reply" =~ ^[Yy]$ ]]
}

validate_name() {
    local name="$1"
    [[ "$name" =~ ^[a-zA-Z0-9][a-zA-Z0-9._-]{0,62}$ ]] \
        || die "Invalid sandbox name: '${name}' — only alphanumeric, hyphens, dots, underscores allowed (max 63 chars)"
}

json_get() {
    local file="$1" key="$2"
    python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d.get(sys.argv[2],''))" "$file" "$key" 2>/dev/null
}

json_set() {
    local file="$1" key="$2" val="$3"
    python3 -c "
import json,sys
f=sys.argv[1]; k=sys.argv[2]; v=json.loads(sys.argv[3])
try:
    d=json.load(open(f))
except:
    d={}
d[k]=v
json.dump(d,open(f,'w'),indent=2)
" "$file" "$key" "$val"
}

# ── Prerequisite checks ─────────────────────────────────────────────────────

check_container_cli() {
    if ! command -v container &>/dev/null; then
        die "Apple Container CLI not found. Install from: https://github.com/apple/container/releases"
    fi
}

check_image() {
    container image ls 2>/dev/null | grep -q "${IMAGE_NAME}" 2>/dev/null
}

ensure_image() {
    if ! check_image; then
        echo ""
        info "Container image '${IMAGE_REF}' not found."
        info "Building image from Containerfile (this takes a few minutes on first run)..."
        echo ""
        cmd_build
    fi
}

ensure_dns() {
    # Set up DNS domain for <name>.test hostnames
    if ! container system dns list 2>/dev/null | grep -q "${DNS_DOMAIN}" 2>/dev/null; then
        info "Setting up DNS domain '${DNS_DOMAIN}'..."
        sudo container system dns create "${DNS_DOMAIN}" 2>/dev/null || true
    fi
}

# ── SSH key management ───────────────────────────────────────────────────────

find_ssh_pubkey() {
    local key_types=("id_ed25519" "id_rsa" "id_ecdsa")
    for kt in "${key_types[@]}"; do
        local kf="$HOME/.ssh/${kt}.pub"
        if [[ -f "$kf" ]]; then
            echo "$kf"
            return 0
        fi
    done
    return 1
}

find_ssh_privkey() {
    local key_types=("id_ed25519" "id_rsa" "id_ecdsa")
    for kt in "${key_types[@]}"; do
        local kf="$HOME/.ssh/${kt}"
        if [[ -f "$kf" ]]; then
            echo "$kf"
            return 0
        fi
    done
    return 1
}

inject_ssh_key() {
    local name="$1"
    local pubkey_file
    if pubkey_file=$(find_ssh_pubkey); then
        local err_output
        err_output=$(cat "$pubkey_file" | container exec -i "$name" bash -c \
            "mkdir -p /home/${DEFAULT_USER}/.ssh && \
             chmod 700 /home/${DEFAULT_USER}/.ssh && \
             cat >> /home/${DEFAULT_USER}/.ssh/authorized_keys && \
             sort -u -o /home/${DEFAULT_USER}/.ssh/authorized_keys /home/${DEFAULT_USER}/.ssh/authorized_keys && \
             chmod 600 /home/${DEFAULT_USER}/.ssh/authorized_keys && \
             chown -R ${DEFAULT_USER}:${DEFAULT_USER} /home/${DEFAULT_USER}/.ssh" \
            2>&1) || {
            warn "SSH key injection failed: ${err_output}"
            return 1
        }
        # Verify the key was actually written
        local key_count
        key_count=$(container exec "$name" bash -c \
            "wc -l < /home/${DEFAULT_USER}/.ssh/authorized_keys" 2>/dev/null)
        if [[ -n "$key_count" ]] && (( key_count > 0 )); then
            msg "SSH key injected (${key_count} key(s) in authorized_keys)"
        else
            warn "SSH key injection may have failed — authorized_keys appears empty"
            # Retry with explicit write as fallback
            container exec "$name" bash -c \
                "echo '$(cat "$pubkey_file")' >> /home/${DEFAULT_USER}/.ssh/authorized_keys && \
                 sort -u -o /home/${DEFAULT_USER}/.ssh/authorized_keys /home/${DEFAULT_USER}/.ssh/authorized_keys && \
                 chmod 600 /home/${DEFAULT_USER}/.ssh/authorized_keys && \
                 chown -R ${DEFAULT_USER}:${DEFAULT_USER} /home/${DEFAULT_USER}/.ssh" \
                2>/dev/null && msg "SSH key injected (fallback method)" || warn "SSH key injection failed completely"
        fi
    else
        warn "No SSH public key found (~/.ssh/id_ed25519.pub, id_rsa.pub, etc.)"
        warn "VS Code Remote SSH requires a key. Run: ssh-keygen -t ed25519"
    fi
}

# ── Container helpers ────────────────────────────────────────────────────────

container_exists() {
    container ls -a 2>/dev/null | grep -qw "$1"
}

container_running() {
    container ls 2>/dev/null | grep -qw "$1"
}

container_ip() {
    local name="$1"
    container ls --format json 2>/dev/null | python3 -c "
import json, sys
target = sys.argv[1]
try:
    data = json.load(sys.stdin)
except:
    sys.exit(0)
for c in data:
    if not isinstance(c, dict):
        continue
    cid = c.get('configuration', {}).get('id', '')
    if cid == target:
        nets = c.get('networks', [])
        if isinstance(nets, list):
            for n in nets:
                addr = n.get('ipv4Address', '')
                if addr:
                    print(addr.split('/')[0])
                    sys.exit(0)
        break
" "$name" 2>/dev/null || true
}

wait_container_ssh() {
    local name="$1"
    local timeout="${2:-60}"
    local elapsed=0
    info "Waiting for container SSH to become ready..."
    while (( elapsed < timeout )); do
        local ip=$(container_ip "$name")
        if [[ -n "$ip" ]] && nc -z -G 2 "$ip" 22 &>/dev/null; then
            msg "Container SSH ready at ${ip}"
            return 0
        fi
        sleep 1
        elapsed=$((elapsed + 1))
        printf "\r${CYAN}⏳${NC} %ds / %ds" "$elapsed" "$timeout"
    done
    printf "\n"
    warn "SSH not reachable after ${timeout}s."
    return 1
}

# ── Naming ───────────────────────────────────────────────────────────────────

derive_name() {
    local dir_path="$1"
    local abs_path=$(cd "$dir_path" 2>/dev/null && pwd -P) || die "Invalid path: $dir_path"
    local dirname=$(basename "$abs_path" | tr '[:upper:]' '[:lower:]' | tr -cd 'a-z0-9-')
    local hash=$(echo -n "$abs_path" | shasum -a 1 | cut -c1-4)
    echo "srl-${dirname}-${hash}"
}

# ── Init ─────────────────────────────────────────────────────────────────────

init_config() {
    mkdir -p "$SANDBOXES_DIR"
    if [[ ! -f "$CONFIG_FILE" ]]; then
        cat > "$CONFIG_FILE" <<'JSON'
{
  "default_cpus": 2,
  "default_mem": 4
}
JSON
    fi
}

# ── SSH config integration ───────────────────────────────────────────────────

update_ssh_config() {
    local name="$1"
    local ip="$2"
    local ssh_config="$HOME/.ssh/config"

    mkdir -p "$HOME/.ssh"
    [[ ! -f "$ssh_config" ]] && touch "$ssh_config" && chmod 600 "$ssh_config"

    # Find the private key file to set IdentityFile
    local identity_line=""
    local privkey_file
    if privkey_file=$(find_ssh_privkey); then
        identity_line="    IdentityFile ${privkey_file}"
    fi

    # Remove existing entry for this sandbox
    local marker_start="# srl-sandbox-begin:${name}"
    local marker_end="# srl-sandbox-end:${name}"
    if grep -q "$marker_start" "$ssh_config" 2>/dev/null; then
        sed -i '' "\|${marker_start}|,\|${marker_end}|d" "$ssh_config"
    fi

    # Add new entry
    cat >> "$ssh_config" <<SSH_ENTRY
${marker_start}
Host ${name}
    HostName ${ip}
    User ${DEFAULT_USER}
    StrictHostKeyChecking accept-new
    UserKnownHostsFile /dev/null
${identity_line:+${identity_line}
}    AddKeysToAgent yes
    LogLevel ERROR
${marker_end}
SSH_ENTRY

    chmod 600 "$ssh_config"
    msg "SSH config updated: Host ${name} → ${ip}"
}

remove_ssh_config() {
    local name="$1"
    local ssh_config="$HOME/.ssh/config"
    [[ ! -f "$ssh_config" ]] && return

    local marker_start="# srl-sandbox-begin:${name}"
    local marker_end="# srl-sandbox-end:${name}"
    if grep -q "$marker_start" "$ssh_config" 2>/dev/null; then
        sed -i '' "\|${marker_start}|,\|${marker_end}|d" "$ssh_config"
    fi
}

# ── State management ────────────────────────────────────────────────────────

sandbox_state_file() {
    echo "$SANDBOXES_DIR/$1.json"
}

save_sandbox_state() {
    local name="$1" proj_path="$2" cpus="$3" mem="$4"
    local extra_mounts="${5:-}"
    local guest_project="${6:-/home/${DEFAULT_USER}/$(basename "$proj_path")}"
    local created=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    python3 -c "
import json,sys
d = {
    'name': sys.argv[1],
    'project_path': sys.argv[2],
    'guest_project': sys.argv[3],
    'cpus': int(sys.argv[4]),
    'mem': int(sys.argv[5]),
    'extra_mounts': sys.argv[6],
    'created': sys.argv[7]
}
json.dump(d, open(sys.argv[8], 'w'), indent=2)
" "$name" "$proj_path" "$guest_project" "$cpus" "$mem" "$extra_mounts" "$created" "$(sandbox_state_file "$name")"
}

list_sandbox_names() {
    local f
    for f in "$SANDBOXES_DIR"/*.json(N); do
        basename "$f" .json
    done
}

# ── Interactive TUI Menu ────────────────────────────────────────────────────
# Arrow-key based multi-select with ↑↓ navigation, Space toggle, Enter confirm.

tui_multiselect() {
    local _result_var=$1; shift
    local -a labels=() descs=() states=()
    local i=0

    # Parse options: "label|description|on_or_off"
    for opt in "$@"; do
        labels+=("${opt%%|*}")
        local rest="${opt#*|}"
        descs+=("${rest%%|*}")
        local default="${rest##*|}"
        if [[ "$default" == "on" ]]; then
            states+=("on")
        else
            states+=("off")
        fi
        i=$((i + 1))
    done

    local count=${#labels[@]}
    local cursor=0

    # Hide cursor
    printf '\033[?25l'

    _tui_draw() {
        # Move up to menu start and redraw
        for (( j=0; j<count+1; j++ )); do
            printf '\033[2K'
            if (( j < count )); then
                printf '\033[1A'
            fi
        done
        printf '\r'

        for (( j=0; j<count; j++ )); do
            local prefix="  "
            local check="${DIM}☐${NC}"
            local label_color=""

            if (( j == cursor )); then
                prefix="${CYAN}▸${NC} "
            fi

            if [[ "${states[$((j+1))]}" == "on" ]]; then
                check="${GREEN}☑${NC}"
                label_color="${BOLD}"
            fi

            printf "  %b%b %b%s${NC}" "$prefix" "$check" "$label_color" "${labels[$((j+1))]}"
            if [[ -n "${descs[$((j+1))]}" ]]; then
                printf "  ${DIM}%s${NC}" "${descs[$((j+1))]}"
            fi
            printf "\n"
        done
        printf "\n  ${DIM}↑↓ navigate · Space toggle · Enter confirm${NC}"
    }

    # Print initial placeholder lines
    for (( j=0; j<count; j++ )); do
        printf "\n"
    done
    printf "\n"
    _tui_draw

    # Input loop
    while true; do
        local key
        read -rsk1 key

        case "$key" in
            $'\e')
                local seq
                read -rsk2 -t 0.1 seq 2>/dev/null || true
                case "$seq" in
                    '[A') cursor=$(( (cursor - 1 + count) % count )) ;;
                    '[B') cursor=$(( (cursor + 1) % count )) ;;
                esac
                ;;
            ' ')
                local idx=$((cursor + 1))
                if [[ "${states[$idx]}" == "on" ]]; then
                    states[$idx]="off"
                else
                    states[$idx]="on"
                fi
                ;;
            $'\n'|'')
                break
                ;;
            'q')
                printf '\033[?25h\n'
                return 1
                ;;
        esac

        _tui_draw
    done

    # Collect results
    eval "${_result_var}=()"
    for (( j=1; j<=count; j++ )); do
        if [[ "${states[$j]}" == "on" ]]; then
            eval "${_result_var}+=($((j - 1)))"
        fi
    done

    printf '\033[?25h\n'
}

# ── Sync ─────────────────────────────────────────────────────────────────────

cmd_sync_internal() {
    local name="$1"
    local proj_path="${2:-}"
    local guest_project="${3:-}"

    # ── Derive guest project path if not given ───────────────────────────
    if [[ -z "$guest_project" && -n "$proj_path" ]]; then
        guest_project="/home/${DEFAULT_USER}/$(basename "$proj_path")"
    fi

    # ── Project path symlink (mirror host path inside container) ─────────
    if [[ -n "$proj_path" && -n "$guest_project" ]]; then
        local parent_dir=$(dirname "$proj_path")
        info "Creating project path symlink..."
        container exec "$name" bash -c \
            "mkdir -p '${parent_dir}' && ln -sfn '${guest_project}' '${proj_path}'" \
            2>/dev/null || warn "Project path symlink may have failed"
    fi

    # ── Claude & AWS config symlinks (only if mounts exist) ─────────────
    container exec "$name" bash -c \
        "[ -e /mnt/claude ] && ln -sfn /mnt/claude /home/${DEFAULT_USER}/.claude 2>/dev/null; \
         [ -e /mnt/claude.json ] && ln -sfn /mnt/claude.json /home/${DEFAULT_USER}/.claude.json 2>/dev/null; \
         [ -e /mnt/aws ] && ln -sfn /mnt/aws /home/${DEFAULT_USER}/.aws 2>/dev/null; \
         chown -h ${DEFAULT_USER}:${DEFAULT_USER} /home/${DEFAULT_USER}/.claude /home/${DEFAULT_USER}/.claude.json /home/${DEFAULT_USER}/.aws 2>/dev/null" \
        2>/dev/null || true

    # ── Git config sync ──────────────────────────────────────────────────
    info "Syncing Git configuration..."
    local git_synced=false
    if [[ -f "$HOME/.gitconfig" ]]; then
        cat "$HOME/.gitconfig" | container exec -i "$name" \
            bash -c "cat > /home/${DEFAULT_USER}/.gitconfig && chown ${DEFAULT_USER}:${DEFAULT_USER} /home/${DEFAULT_USER}/.gitconfig" \
            2>/dev/null && git_synced=true || warn "Failed to copy .gitconfig"
    fi
    if [[ -f "$HOME/.gitconfig.local" ]]; then
        cat "$HOME/.gitconfig.local" | container exec -i "$name" \
            bash -c "cat > /home/${DEFAULT_USER}/.gitconfig.local && chown ${DEFAULT_USER}:${DEFAULT_USER} /home/${DEFAULT_USER}/.gitconfig.local" \
            2>/dev/null || warn "Failed to copy .gitconfig.local"
    fi
    $git_synced && msg "Git config synced"

    # ── GitHub auth sync ─────────────────────────────────────────────────
    if command -v gh &>/dev/null && gh auth status &>/dev/null; then
        info "Syncing GitHub authentication..."
        local gh_token
        gh_token=$(gh auth token 2>/dev/null)
        if [[ -n "$gh_token" ]]; then
            echo "$gh_token" | container exec -i "$name" su - "${DEFAULT_USER}" -c \
                "command -v gh &>/dev/null && gh auth login --with-token 2>/dev/null && gh auth setup-git 2>/dev/null" \
                2>/dev/null \
                && msg "GitHub auth synced (gh CLI)" \
                || warn "GitHub auth sync failed"
        fi
    else
        step "GitHub CLI not authenticated on host — skipping"
    fi
}

cmd_sync() {
    [[ $# -lt 1 ]] && die "Usage: srl-sandbox sync <name>"
    local name="$1"
    container_exists "$name" || die "Sandbox '$name' not found"
    container_running "$name" || die "Sandbox '$name' is not running"

    local state_file=$(sandbox_state_file "$name")
    local proj_path="" guest_project=""
    if [[ -f "$state_file" ]]; then
        proj_path=$(json_get "$state_file" "project_path")
        guest_project=$(json_get "$state_file" "guest_project")
    fi

    cmd_sync_internal "$name" "$proj_path" "$guest_project"
    msg "Sync complete for $name"
}

# ── Platform Dependency Shadow Overlay ───────────────────────────────────────
# Auto-detects project ecosystems and creates container-local bind mounts
# over platform-specific directories (node_modules, .venv) so macOS artifacts
# don't interfere with the Linux sandbox.

readonly SHADOW_BASE="/home/${DEFAULT_USER}/.sandbox-deps"

detect_ecosystems() {
    local name="$1" guest_project="$2"
    local -a found=()

    if container exec "$name" test -f "${guest_project}/package.json" 2>/dev/null; then
        found+=(node)
    fi

    if container exec "$name" bash -c \
        "test -f '${guest_project}/requirements.txt' || \
         test -f '${guest_project}/pyproject.toml' || \
         test -f '${guest_project}/Pipfile' || \
         test -f '${guest_project}/setup.py' || \
         test -f '${guest_project}/setup.cfg'" 2>/dev/null; then
        found+=(python)
    fi

    echo "${found[*]}"
}

setup_node_shadow() {
    local name="$1" guest_project="$2" shadow_dir="$3"
    local shadow_nm="${shadow_dir}/node_modules"

    info "Setting up Node.js dependencies (Linux)..."

    container exec "$name" bash -c "
        set -e
        mkdir -p '${shadow_nm}'
        chown ${DEFAULT_USER}:${DEFAULT_USER} '${shadow_nm}'
        mkdir -p '${guest_project}/node_modules'
        mount --bind '${shadow_nm}' '${guest_project}/node_modules'
    " || { warn "Node.js shadow overlay failed"; return 1; }

    container exec "$name" su - "${DEFAULT_USER}" -c "
        set -o pipefail
        export NVM_DIR=\"\$HOME/.nvm\"
        [ -s \"\$NVM_DIR/nvm.sh\" ] && . \"\$NVM_DIR/nvm.sh\"
        cd '${guest_project}' && npm install 2>&1 | tail -5
    " && msg "Node.js dependencies installed" \
        || warn "npm install failed — run manually inside sandbox"
}

setup_python_shadow() {
    local name="$1" guest_project="$2" shadow_dir="$3"

    # Detect existing venv directory name on the host mount
    local venv_name=".venv"
    for candidate in .venv venv; do
        if container exec "$name" test -d "${guest_project}/${candidate}" 2>/dev/null; then
            venv_name="$candidate"
            break
        fi
    done

    local shadow_venv="${shadow_dir}/${venv_name}"
    local target_venv="${guest_project}/${venv_name}"

    info "Setting up Python environment (Linux)..."

    container exec "$name" bash -c "
        set -e
        mkdir -p '${shadow_venv}'
        chown ${DEFAULT_USER}:${DEFAULT_USER} '${shadow_venv}'
        mkdir -p '${target_venv}'
        mount --bind '${shadow_venv}' '${target_venv}'
    " || { warn "Python shadow overlay failed"; return 1; }

    container exec "$name" su - "${DEFAULT_USER}" -c "
        cd '${guest_project}'
        python3 -m venv '${target_venv}'
        . '${target_venv}/bin/activate'
        pip install --upgrade pip -q
        if [ -f requirements.txt ]; then
            pip install -r requirements.txt -q
        elif [ -f pyproject.toml ]; then
            if ! pip install -e '.[dev]' -q 2>&1; then
                echo 'dev extras failed, installing base only' >&2
                pip install -e . -q
            fi
        elif [ -f Pipfile ]; then
            pip install pipenv -q && pipenv install --dev
        elif [ -f setup.py ] || [ -f setup.cfg ]; then
            pip install -e . -q
        fi
    " && msg "Python environment ready" \
        || warn "Python setup incomplete — run manually inside sandbox"
}

cleanup_platform_artifacts() {
    local name="$1" guest_project="$2"

    step "Cleaning macOS artifacts..."
    container exec "$name" su - "${DEFAULT_USER}" -c "
        cd '${guest_project}'
        find . -name '.DS_Store' -delete 2>/dev/null
        find . -name '__pycache__' -type d -exec rm -rf {} + 2>/dev/null
        find . -name '*.pyc' -delete 2>/dev/null
    " 2>/dev/null || true
}

setup_shadow_deps() {
    local name="$1" guest_project="$2"
    local proj_name=$(basename "$guest_project")
    local shadow_dir="${SHADOW_BASE}/${proj_name}"

    info "Detecting project dependencies..."
    local ecosystems
    ecosystems=$(detect_ecosystems "$name" "$guest_project")

    if [[ -z "$ecosystems" ]]; then
        step "No dependency ecosystems detected"
        cleanup_platform_artifacts "$name" "$guest_project"
        return 0
    fi

    msg "Detected: ${BOLD}${ecosystems}${NC}"

    container exec "$name" su - "${DEFAULT_USER}" -c \
        "mkdir -p '${shadow_dir}'" \
        || { warn "Failed to create shadow directory '${shadow_dir}'"; return 0; }

    for eco in ${=ecosystems}; do
        case "$eco" in
            node)   setup_node_shadow "$name" "$guest_project" "$shadow_dir" || true ;;
            python) setup_python_shadow "$name" "$guest_project" "$shadow_dir" || true ;;
        esac
    done

    cleanup_platform_artifacts "$name" "$guest_project"
}

restore_shadow_deps() {
    local name="$1" guest_project="$2"
    local proj_name=$(basename "$guest_project")
    local shadow_dir="${SHADOW_BASE}/${proj_name}"

    container exec "$name" test -d "$shadow_dir" 2>/dev/null || return 0

    info "Restoring dependency overlays..."

    if container exec "$name" test -d "${shadow_dir}/node_modules" 2>/dev/null; then
        container exec "$name" bash -c "
            set -e
            mkdir -p '${guest_project}/node_modules'
            chown ${DEFAULT_USER}:${DEFAULT_USER} '${guest_project}/node_modules'
            mount --bind '${shadow_dir}/node_modules' '${guest_project}/node_modules'
        " && msg "Node.js overlay restored" \
            || warn "Node.js overlay restore failed"
    fi

    for candidate in .venv venv; do
        if container exec "$name" test -d "${shadow_dir}/${candidate}" 2>/dev/null; then
            container exec "$name" bash -c "
                set -e
                mkdir -p '${guest_project}/${candidate}'
                chown ${DEFAULT_USER}:${DEFAULT_USER} '${guest_project}/${candidate}'
                mount --bind '${shadow_dir}/${candidate}' '${guest_project}/${candidate}'
            " && msg "Python overlay restored" \
                || warn "Python overlay restore failed"
            break
        fi
    done
}

# ── VS Code Extension & Settings Sync ───────────────────────────────────────

_find_remote_code_server() {
    local name="$1"
    container exec "$name" su - "${DEFAULT_USER}" -c \
        "ls ~/.vscode-server/cli/servers/Stable-*/server/bin/code-server 2>/dev/null | head -1" \
        2>/dev/null
}

cmd_sync_extensions() {
    [[ $# -lt 1 ]] && die "Usage: srl-sandbox sync-extensions <name>"
    local name="$1"
    container_exists "$name" || die "Sandbox '$name' not found"
    container_running "$name" || die "Sandbox '$name' is not running"

    # Check host VS Code CLI
    if ! command -v code &>/dev/null; then
        die "VS Code CLI 'code' not found on host. Open VS Code and install the shell command."
    fi

    # Find code-server on the remote
    local code_server
    code_server=$(_find_remote_code_server "$name")
    if [[ -z "$code_server" ]]; then
        die "VS Code Server not found in sandbox. Connect VS Code Remote SSH first, then re-run."
    fi

    # Get host extensions
    info "Listing host VS Code extensions..."
    local -a host_exts=()
    while IFS= read -r ext; do
        [[ -n "$ext" ]] && host_exts+=("$ext")
    done < <(code --list-extensions 2>/dev/null)

    if [[ ${#host_exts[@]} -eq 0 ]]; then
        warn "No extensions found on host."
        return
    fi
    msg "Found ${#host_exts[@]} extensions on host"

    # Get remote extensions
    info "Listing remote extensions..."
    local -a remote_exts=()
    while IFS= read -r ext; do
        [[ -n "$ext" ]] && remote_exts+=("${ext:l}")  # lowercase for comparison
    done < <(container exec "$name" su - "${DEFAULT_USER}" -c \
        "'${code_server}' --list-extensions 2>/dev/null" 2>/dev/null)

    # UI-only extensions that don't need to be installed remotely
    local -a skip_patterns=(
        "theme" "icon" "color" "bracket" "indent-rainbow"
        "vscode-icons" "material-icon" "one-dark" "dracula"
    )

    # Build list of extensions to install
    local -a to_install=()
    local skipped=0
    for ext in "${host_exts[@]}"; do
        local ext_lower="${ext:l}"

        # Skip if already installed
        if printf '%s\n' "${remote_exts[@]}" | grep -qxi "$ext_lower"; then
            skipped=$((skipped + 1))
            continue
        fi

        # Skip UI-only extensions (themes, icons)
        local is_ui=false
        for pattern in "${skip_patterns[@]}"; do
            if [[ "$ext_lower" == *"$pattern"* ]]; then
                is_ui=true
                break
            fi
        done
        if $is_ui; then
            step "Skipping UI extension: $ext"
            skipped=$((skipped + 1))
            continue
        fi

        to_install+=("$ext")
    done

    if [[ ${#to_install[@]} -eq 0 ]]; then
        msg "Extension sync: 0 installed, ${skipped} skipped, 0 failed"
        # fall through to settings sync
    else
        # Batch all installs into a single container exec to avoid per-extension
        # process spawn overhead (~40 execs → 1 exec)
        info "Installing ${#to_install[@]} extensions in single batch..."
        local install_script="installed=0; failed=0"
        for ext in "${to_install[@]}"; do
            install_script+="; if '${code_server}' --install-extension '${ext}' --force >/dev/null 2>&1; then installed=\$((installed+1)); echo \"OK: ${ext}\"; else failed=\$((failed+1)); echo \"FAIL: ${ext}\"; fi"
        done
        install_script+='; echo "RESULT:${installed}:${failed}"'

        local batch_output
        batch_output=$(container exec "$name" su - "${DEFAULT_USER}" -c "$install_script" 2>/dev/null)

        # Parse results from batch output
        local installed=0 failed=0
        local result_line
        result_line=$(echo "$batch_output" | grep '^RESULT:' | tail -1)
        if [[ -n "$result_line" ]]; then
            installed=$(echo "$result_line" | cut -d: -f2)
            failed=$(echo "$result_line" | cut -d: -f3)
        fi

        # Show any failures
        echo "$batch_output" | grep '^FAIL:' | while IFS= read -r line; do
            warn "Failed to install: ${line#FAIL: }"
        done

        echo ""
        msg "Extension sync: ${installed} installed, ${skipped} skipped, ${failed} failed"
    fi

    # Sync settings if requested
    local host_settings="$HOME/Library/Application Support/Code/User/settings.json"
    if [[ -f "$host_settings" ]]; then
        info "Syncing VS Code settings..."
        container exec "$name" su - "${DEFAULT_USER}" -c \
            "mkdir -p ~/.vscode-server/data/Machine" 2>/dev/null
        cat "$host_settings" | container exec -i "$name" su - "${DEFAULT_USER}" -c \
            "cat > ~/.vscode-server/data/Machine/settings.json" \
            2>/dev/null && msg "VS Code settings synced" \
            || warn "Settings sync failed"
    fi
}

# ── Code Server (on-demand) ─────────────────────────────────────────────────

install_and_start_code_server() {
    local name="$1"
    local ip="$2"
    local folder="${3:-/home/${DEFAULT_USER}}"

    info "Installing code-server (on-demand)..."
    container exec "$name" su - "${DEFAULT_USER}" -c \
        "curl -fsSL https://code-server.dev/install.sh | sh -s -- --method=standalone 2>/dev/null" \
        2>/dev/null || { warn "code-server installation failed"; return 1; }

    info "Starting code-server..."
    container exec -d "$name" su - "${DEFAULT_USER}" -c \
        "code-server --bind-addr 127.0.0.1:8080 --auth none '${folder}' &>/dev/null &" \
        2>/dev/null || { warn "code-server start failed"; return 1; }

    local elapsed=0 timeout=20
    while (( elapsed < timeout )); do
        if nc -z -G 2 "$ip" 8080 &>/dev/null; then
            msg "Code Server: ${BOLD}http://${ip}:8080${NC}"
            return 0
        fi
        sleep 1
        elapsed=$((elapsed + 1))
    done
    warn "code-server not reachable after ${timeout}s"
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_build() {
    [[ ! -f "$CONTAINERFILE" ]] && die "Containerfile not found at $CONTAINERFILE"

    local -a build_args=()
    local python_version=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --python)  python_version="$2"; shift 2 ;;
            -*)        die "Unknown build option: $1" ;;
            *)         shift ;;
        esac
    done

    if [[ -n "$python_version" ]]; then
        build_args+=(--build-arg "PYTHON_VERSION=${python_version}")
        info "Building container image '${IMAGE_REF}' with Python ${python_version}..."
    else
        info "Building container image '${IMAGE_REF}'..."
    fi
    info "Includes: Debian Bookworm, Python, Node.js 24, Claude Code, gh, AWS CLI, SSH"
    echo ""

    container build "${build_args[@]}" -t "${IMAGE_REF}" "$SCRIPT_DIR" || die "Image build failed"

    echo ""
    success "Image '${IMAGE_REF}' built successfully"
}

cmd_launch() {
    local proj_path=""
    local name=""
    local cpus=$DEFAULT_CPUS
    local mem=$DEFAULT_MEM
    local no_sync=false
    local no_config=false
    local mirror=false
    local headless=false
    local -a extra_mounts=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --name)      name="$2"; shift 2 ;;
            --cpus)      cpus="$2"; shift 2 ;;
            --mem)       mem="$2"; shift 2 ;;
            --mount)     extra_mounts+=("$2"); shift 2 ;;
            --no-sync)   no_sync=true; shift ;;
            --no-config) no_config=true; shift ;;
            --mirror)    mirror=true; shift ;;
            --headless|--detach|-d) headless=true; shift ;;
            -*)          die "Unknown option: $1" ;;
            *)           proj_path="$1"; shift ;;
        esac
    done

    [[ -z "$proj_path" ]] && proj_path="$(pwd)"
    proj_path=$(cd "$proj_path" 2>/dev/null && pwd -P) || die "Invalid path: $proj_path"
    [[ -z "$name" ]] && name=$(derive_name "$proj_path")
    validate_name "$name"

    local proj_dirname=$(basename "$proj_path")
    [[ "$proj_dirname" == *"'"* ]] && die "Project directory name contains unsupported characters (single quote)"
    local guest_project="/home/${DEFAULT_USER}/${proj_dirname}"

    # Load guest_project from state if the sandbox already exists
    local state_file=$(sandbox_state_file "$name")
    if [[ -f "$state_file" ]]; then
        local saved_gp=$(json_get "$state_file" "guest_project")
        [[ -n "$saved_gp" ]] && guest_project="$saved_gp"
    fi

    echo ""
    header "SRL Sandbox v${VERSION}"
    msg "Sandbox: ${BOLD}$name${NC} → $proj_path"

    ensure_image
    ensure_dns

    if container_running "$name"; then
        info "Sandbox '${name}' is already running"
        echo ""
        printf "${YELLOW}%s${NC}\n" "  1) Reuse existing sandbox"
        printf "${YELLOW}%s${NC}\n" "  2) Destroy and recreate"
        printf "${YELLOW}%s${NC} " "  Choose [1]: "
        read -r choice
        case "${choice:-1}" in
            2)
                info "Destroying existing sandbox..."
                container stop "$name" 2>/dev/null || true
                container rm "$name" 2>/dev/null || true
                ;; # container destroyed; will be recreated below
            1|*)
                ;; # reuse — skip to post-creation setup
        esac
    elif container_exists "$name"; then
        info "Sandbox '${name}' exists but is stopped"
        echo ""
        printf "${YELLOW}%s${NC}\n" "  1) Resume existing sandbox"
        printf "${YELLOW}%s${NC}\n" "  2) Destroy and recreate"
        printf "${YELLOW}%s${NC} " "  Choose [1]: "
        read -r choice
        case "${choice:-1}" in
            2)
                info "Destroying existing sandbox..."
                container rm "$name" 2>/dev/null || true
                ;; # container no longer exists; will be recreated below
            1|*)
                info "Starting stopped container..."
                container start "$name" || die "Failed to start container"
                wait_container_ssh "$name" || true
                # Restore bind-mount overlays from previous session
                if [[ "$mirror" == true ]]; then
                    restore_shadow_deps "$name" "$guest_project"
                fi
                ;;
        esac
    fi

    if ! container_running "$name"; then
        # ── Create new container ─────────────────────────────────────────
        info "Creating container: ${cpus} CPUs, ${mem} GiB RAM"

        local -a run_args=(
            run -d
            --name "$name"
            --cpus "$cpus"
            --memory "${mem}G"
            --volume "${proj_path}:${guest_project}"
        )

        if [[ "$no_config" != true ]]; then
            mkdir -p "$HOME/.claude" "$HOME/.aws"
            touch "$HOME/.claude.json"  # ensure file exists for volume mount
            run_args+=(
                --volume "$HOME/.claude:/mnt/claude"
                --volume "$HOME/.claude.json:/mnt/claude.json"
                --volume "$HOME/.aws:/mnt/aws"
            )
        fi

        for mount_spec in "${extra_mounts[@]}"; do
            run_args+=(--volume "$mount_spec")
        done

        run_args+=("$IMAGE_REF")

        container "${run_args[@]}" || die "Failed to create container"

        wait_container_ssh "$name" || warn "Container started but SSH may not be ready"

        if [[ "$no_sync" != true ]]; then
            cmd_sync_internal "$name" "$proj_path" "$guest_project"
        fi

        # Set up platform-native dependencies via shadow overlay
        if [[ "$mirror" == true ]]; then
            setup_shadow_deps "$name" "$guest_project"
        fi

        local ip=$(container_ip "$name")
        if [[ -n "$ip" ]]; then
            update_ssh_config "$name" "$ip"
        fi

        save_sandbox_state "$name" "$proj_path" "$cpus" "$mem" \
            "$(IFS=','; echo "${extra_mounts[*]}")" "$guest_project"
    fi

    # Always ensure SSH key is injected (idempotent via sort -u)
    inject_ssh_key "$name"

    # Refresh IP
    local ip=$(container_ip "$name")
    if [[ -n "$ip" ]]; then
        update_ssh_config "$name" "$ip"
        msg "Container IP: ${BOLD}${ip}${NC}"
        msg "Hostname: ${BOLD}${name}.${DNS_DOMAIN}${NC}"
    fi

    if [[ "$headless" == true ]]; then
        info "Headless mode — use 'srl-sandbox ssh $name' to connect"
        return
    fi

    # ── Lifecycle: stop sandbox when CLI exits ───────────────────────────
    trap "stty echo 2>/dev/null; echo ''; info 'Stopping sandbox...'; container stop '$name' 2>/dev/null || true; msg 'Sandbox stopped.'; trap - EXIT HUP TERM INT" EXIT HUP TERM INT

    # ── Interactive launch ───────────────────────────────────────────────
    echo ""
    if confirm_default_yes "Use defaults? (VS Code Remote SSH)"; then
        _launch_vscode_remote "$name" "$ip" "$guest_project"
    else
        echo ""
        header "Configure"

        local -a selected=()
        tui_multiselect selected \
            "VS Code Remote SSH|Connect host VS Code via SSH|on" \
            "Claude Code|Launch Claude Code in terminal|off" \
            "Skip Permissions|--dangerously-skip-permissions|off" \
            "Code Server|Browser VS Code (installed on demand)|off" \
            "Shell Only|Drop into zsh shell|off"

        local run_vscode=false
        local run_claude=false
        local run_skip_perms=false
        local run_code_server=false
        local run_shell=false

        for idx in "${selected[@]}"; do
            case $idx in
                0) run_vscode=true ;;
                1) run_claude=true ;;
                2) run_skip_perms=true ;;
                3) run_code_server=true ;;
                4) run_shell=true ;;
            esac
        done

        echo ""

        if $run_code_server && [[ -n "$ip" ]]; then
            install_and_start_code_server "$name" "$ip" "$guest_project"
        fi

        if $run_vscode; then
            _launch_vscode_remote "$name" "$ip" "$guest_project"
        fi

        if $run_claude; then
            _launch_claude "$name" "$run_skip_perms" "$guest_project"
        elif $run_shell; then
            _launch_shell "$name" "$guest_project"
        fi
    fi

    # ── Foreground wait ──────────────────────────────────────────────────
    _foreground_wait "$name"
}

_foreground_wait() {
    local name="$1"

    # If the container is no longer running (e.g. user exited an interactive
    # session and the container stopped), skip the wait.
    container_running "$name" || return 0

    local ip
    ip=$(container_ip "$name" 2>/dev/null)

    local state_file
    state_file=$(sandbox_state_file "$name")

    echo ""
    msg "${DIM}Sandbox ${BOLD}${name}${NC}${DIM} is running at ${BOLD}${ip:-unknown}${NC}"
    echo ""
    msg "${DIM}  ${BOLD}v${NC}${DIM} = VS Code  ${BOLD}s${NC}${DIM} = SSH  ${BOLD}e${NC}${DIM} = Sync Extensions  ${BOLD}q${NC}${DIM}/Ctrl+C = Stop${NC}"

    # Suppress character echo so keypresses don't print to terminal
    stty -echo 2>/dev/null

    # Read single keypress in a loop
    while container_running "$name"; do
        local key=""
        read -t 2 -k 1 key 2>/dev/null || true

        case "${key:l}" in
            v)
                stty echo 2>/dev/null
                local guest_project
                guest_project=$(json_get "$state_file" guest_project 2>/dev/null)
                _launch_vscode_remote "$name" "$ip" "${guest_project:-/home/${DEFAULT_USER}}"
                echo ""
                msg "${DIM}  ${BOLD}v${NC}${DIM} = VS Code  ${BOLD}s${NC}${DIM} = SSH  ${BOLD}e${NC}${DIM} = Sync Extensions  ${BOLD}q${NC}${DIM}/Ctrl+C = Stop${NC}"
                stty -echo 2>/dev/null
                ;;
            s)
                stty echo 2>/dev/null
                echo ""
                info "Launching SSH session... (type 'exit' to return)"
                ssh -o StrictHostKeyChecking=accept-new "${DEFAULT_USER}@${ip}" 2>/dev/null || true
                echo ""
                msg "${DIM}  ${BOLD}v${NC}${DIM} = VS Code  ${BOLD}s${NC}${DIM} = SSH  ${BOLD}e${NC}${DIM} = Sync Extensions  ${BOLD}q${NC}${DIM}/Ctrl+C = Stop${NC}"
                stty -echo 2>/dev/null
                ;;
            e)
                stty echo 2>/dev/null
                echo ""
                cmd_sync_extensions "$name"
                echo ""
                msg "${DIM}  ${BOLD}v${NC}${DIM} = VS Code  ${BOLD}s${NC}${DIM} = SSH  ${BOLD}e${NC}${DIM} = Sync Extensions  ${BOLD}q${NC}${DIM}/Ctrl+C = Stop${NC}"
                stty -echo 2>/dev/null
                ;;
            q)
                exit 0
                ;;
        esac
    done

    # Container stopped on its own — EXIT trap handles cleanup
    exit 0
}

_launch_vscode_remote() {
    local name="$1"
    local ip="$2"
    local remote_folder="${3:-/home/${DEFAULT_USER}}"
    local remote_uri="vscode://vscode-remote/ssh-remote+${name}${remote_folder}"
    info "Opening VS Code → ${name}:${remote_folder}"
    open "$remote_uri" 2>/dev/null \
        && msg "VS Code Remote SSH launched" \
        || warn "Failed to open VS Code. Ensure the Remote - SSH extension is installed."
}

_launch_claude() {
    local name="$1"
    local skip_perms="$2"
    local guest_project="${3:-/home/${DEFAULT_USER}}"

    if container exec "$name" su - "${DEFAULT_USER}" -c \
        "source ~/.nvm/nvm.sh 2>/dev/null; command -v claude" &>/dev/null; then
        local claude_cmd="source ~/.nvm/nvm.sh 2>/dev/null; cd '${guest_project}' && claude"
        if [[ "$skip_perms" != "true" ]]; then
            if confirm_default_yes "Launch Claude with --dangerously-skip-permissions?"; then
                skip_perms=true
            fi
        fi
        if [[ "$skip_perms" == "true" ]]; then
            claude_cmd+=" --dangerously-skip-permissions"
            info "Launching Claude Code ${DIM}(--dangerously-skip-permissions)${NC}..."
        else
            info "Launching Claude Code..."
        fi
        echo ""
        container exec -ti "$name" su - "${DEFAULT_USER}" -c "$claude_cmd"
    else
        warn "Claude Code not found in container. Falling back to shell."
        _launch_shell "$name" "$guest_project"
    fi
}

_launch_shell() {
    local name="$1"
    local guest_project="${2:-/home/${DEFAULT_USER}}"
    container exec -ti "$name" su - "${DEFAULT_USER}" -c \
        "cd '${guest_project}' 2>/dev/null; exec zsh -l 2>/dev/null || exec bash -l"
}

cmd_stop() {
    [[ $# -lt 1 ]] && die "Usage: srl-sandbox stop <name|all>"
    local target="$1"

    if [[ "$target" == "all" ]]; then
        local names=($(list_sandbox_names))
        [[ ${#names[@]} -eq 0 ]] && { info "No sandboxes found."; return; }
        for n in "${names[@]}"; do
            if container_running "$n"; then
                info "Stopping $n..."
                container stop "$n" 2>/dev/null && msg "Stopped $n" || warn "Failed to stop $n"
            fi
        done
    else
        container_exists "$target" || die "Sandbox '$target' not found"
        info "Stopping $target..."
        container stop "$target" || die "Failed to stop"
        msg "Stopped $target"
    fi
}

cmd_destroy() {
    [[ $# -lt 1 ]] && die "Usage: srl-sandbox destroy <name>"
    local name="$1"

    container_exists "$name" || die "Sandbox '$name' not found"
    confirm "Destroy sandbox '$name'? This cannot be undone." || { info "Cancelled."; return; }

    if container_running "$name"; then
        info "Stopping container first..."
        container stop "$name" 2>/dev/null || true
        sleep 1
    fi

    info "Deleting container..."
    container rm "$name" 2>/dev/null || container delete "$name" 2>/dev/null \
        || die "Failed to delete container"

    remove_ssh_config "$name"

    local state_file=$(sandbox_state_file "$name")
    [[ -f "$state_file" ]] && rm -f "$state_file"

    msg "Destroyed $name"
}

cmd_list() {
    local names=($(list_sandbox_names))

    if [[ ${#names[@]} -eq 0 ]]; then
        info "No sandboxes found."
        return
    fi

    header "Sandboxes"
    printf "  ${BOLD}%-30s  %-10s  %-16s  %s${NC}\n" "NAME" "STATUS" "IP" "PROJECT"
    printf "  ${DIM}%-30s  %-10s  %-16s  %s${NC}\n" \
        "────────────────────────────" "─────────" "───────────────" "───────────────────────"

    local sb_status proj_path ip state_file status_icon color_status
    for name in "${names[@]}"; do
        sb_status="unknown"
        proj_path="-"
        ip="-"

        if container_running "$name"; then
            sb_status="running"
            ip=$(container_ip "$name")
            [[ -z "$ip" ]] && ip="-"
        elif container_exists "$name"; then
            sb_status="stopped"
        else
            sb_status="deleted"
        fi

        state_file=$(sandbox_state_file "$name")
        [[ -f "$state_file" ]] && proj_path=$(json_get "$state_file" "project_path")
        [[ -z "$proj_path" ]] && proj_path="-"

        case "$sb_status" in
            running) status_icon="${GREEN}●${NC}"; color_status="${GREEN}${sb_status}${NC}" ;;
            stopped) status_icon="${RED}●${NC}";   color_status="${RED}${sb_status}${NC}" ;;
            deleted) status_icon="${RED}○${NC}";   color_status="${RED}${sb_status}${NC}" ;;
            *)       status_icon="${DIM}?${NC}";   color_status="$sb_status" ;;
        esac

        printf "  %-30s  %b %-10b  %-16s  ${DIM}%s${NC}\n" \
            "$name" "$status_icon" "$color_status" "$ip" "$proj_path"
    done
    echo ""
}

cmd_ssh() {
    [[ $# -lt 1 ]] && die "Usage: srl-sandbox ssh <name>"
    local name="$1"
    container_exists "$name" || die "Sandbox '$name' not found"
    container_running "$name" || die "Sandbox '$name' is not running"

    local state_file=$(sandbox_state_file "$name")
    local guest_project="/home/${DEFAULT_USER}"
    if [[ -f "$state_file" ]]; then
        local gp=$(json_get "$state_file" "guest_project")
        [[ -n "$gp" && "$gp" != "null" ]] && guest_project="$gp"
    fi

    container exec -ti "$name" su - "${DEFAULT_USER}" -c \
        "cd '${guest_project}' 2>/dev/null; exec zsh -l 2>/dev/null || exec bash -l"
}

cmd_exec() {
    [[ $# -lt 2 ]] && die "Usage: srl-sandbox exec <name> <command...>"
    local name="$1"; shift
    container_exists "$name" || die "Sandbox '$name' not found"
    container_running "$name" || die "Sandbox '$name' is not running"

    container exec "$name" su - "${DEFAULT_USER}" -c "$*"
}

cmd_info() {
    [[ $# -lt 1 ]] && die "Usage: srl-sandbox info <name>"
    local name="$1"
    container_exists "$name" || die "Sandbox '$name' not found"

    local is_running=false
    container_running "$name" && is_running=true

    local state_file=$(sandbox_state_file "$name")
    local proj_path="-" cpus="-" mem="-" created="-" extra_mounts="-" guest_project="/home/${DEFAULT_USER}"
    if [[ -f "$state_file" ]]; then
        proj_path=$(json_get "$state_file" "project_path")
        cpus=$(json_get "$state_file" "cpus")
        mem=$(json_get "$state_file" "mem")
        created=$(json_get "$state_file" "created")
        extra_mounts=$(json_get "$state_file" "extra_mounts")
        local gp=$(json_get "$state_file" "guest_project")
        [[ -n "$gp" && "$gp" != "null" ]] && guest_project="$gp"
    fi

    local ip="-"
    $is_running && ip=$(container_ip "$name")
    [[ -z "$ip" ]] && ip="-"

    local status_display
    if $is_running; then
        status_display="${GREEN}● running${NC}"
    else
        status_display="${RED}● stopped${NC}"
    fi

    header "$name"
    printf "  ${BOLD}%-14s${NC} %b\n" "Status" "$status_display"
    printf "  ${BOLD}%-14s${NC} %s\n" "IP" "$ip"
    printf "  ${BOLD}%-14s${NC} %s.${DNS_DOMAIN}\n" "Hostname" "$name"
    printf "  ${BOLD}%-14s${NC} %s\n" "Project" "${proj_path:-—}"
    printf "  ${BOLD}%-14s${NC} %s vCPU · %s GiB RAM\n" "Resources" "${cpus:-—}" "${mem:-—}"
    printf "  ${BOLD}%-14s${NC} %s\n" "Created" "${created:-—}"

    echo ""
    printf "  ${BOLD}Mounts${NC}\n"
    printf "  ${DIM}%-12s %s → %s${NC}\n" "project" "$proj_path" "$guest_project"
    printf "  ${DIM}%-12s %s → %s${NC}\n" "claude" "~/.claude" "/mnt/claude → ~/.claude"
    printf "  ${DIM}%-12s %s → %s${NC}\n" "claude.json" "~/.claude.json" "/mnt/claude.json → ~/.claude.json"
    printf "  ${DIM}%-12s %s → %s${NC}\n" "aws" "~/.aws" "/mnt/aws → ~/.aws"
    if [[ -n "$extra_mounts" && "$extra_mounts" != "-" ]]; then
        IFS=',' read -rA mount_arr <<< "$extra_mounts"
        for m in "${mount_arr[@]}"; do
            [[ -z "$m" ]] && continue
            printf "  ${DIM}%-12s %s${NC}\n" "extra" "$m"
        done
    fi

    echo ""
    printf "  ${BOLD}Synced Config${NC}\n"
    [[ -f "$HOME/.gitconfig" ]] \
        && printf "  ${DIM}%-12s %s${NC}\n" "git" "~/.gitconfig" \
        || printf "  ${DIM}%-12s %s${NC}\n" "git" "(not found on host)"
    command -v gh &>/dev/null && gh auth status &>/dev/null \
        && printf "  ${DIM}%-12s %s${NC}\n" "github" "gh auth token (synced)" \
        || printf "  ${DIM}%-12s %s${NC}\n" "github" "(gh not authenticated)"

    if $is_running; then
        echo ""
        printf "  ${BOLD}Quick Access${NC}\n"
        printf "  ${CYAN}ssh${NC}     ssh ${name}\n"
        printf "  ${CYAN}vscode${NC}  code --remote ssh-remote+${name} ${guest_project}\n"
        printf "  ${CYAN}claude${NC}  srl-sandbox exec ${name} 'source ~/.nvm/nvm.sh && claude'\n"
    fi
    echo ""
}

cmd_reset() {
    local remove_all=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all)  remove_all=true; shift ;;
            -*)     die "Unknown option: $1" ;;
            *)      die "Usage: srl-sandbox reset [--all]" ;;
        esac
    done

    echo ""
    header "SRL Sandbox Reset"

    if $remove_all; then
        confirm "Destroy ALL sandboxes and remove the base image? This cannot be undone." \
            || { info "Cancelled."; return; }

        # Destroy all sandboxes
        local names=($(list_sandbox_names))
        for n in "${names[@]}"; do
            info "Destroying sandbox: $n"
            container_running "$n" && container stop "$n" 2>/dev/null || true
            sleep 0.5
            container rm "$n" 2>/dev/null || container delete "$n" 2>/dev/null || true
            remove_ssh_config "$n"
            local sf=$(sandbox_state_file "$n")
            [[ -f "$sf" ]] && rm -f "$sf"
        done
    else
        confirm "Remove the base image '${IMAGE_REF}'? Running sandboxes are not affected." \
            || { info "Cancelled."; return; }
    fi

    # Remove the base image
    info "Removing image '${IMAGE_REF}'..."
    container image rm "${IMAGE_REF}" 2>/dev/null \
        && msg "Image '${IMAGE_REF}' removed" \
        || info "Image not found or already removed"

    echo ""
    success "Reset complete. Run 'srl-sandbox build' to rebuild the image."
}

