# ── Ctrl+C Trap ──────────────────────────────────────────────────────────────

trap_handler() {
    echo ""
    warn "Interrupted. Running containers are still active."
    warn "Use 'srl-sandbox list' to see running sandboxes."
    exit 130
}
trap trap_handler INT

# ── Main ─────────────────────────────────────────────────────────────────────

main() {
    init_config

    [[ $# -eq 0 ]] && { check_container_cli; cmd_launch; return; }

    local cmd="$1"; shift

    case "$cmd" in
        launch)            check_container_cli; cmd_launch "$@" ;;
        stop)              check_container_cli; cmd_stop "$@" ;;
        destroy)           check_container_cli; cmd_destroy "$@" ;;
        list)              check_container_cli; cmd_list "$@" ;;
        ssh)               check_container_cli; cmd_ssh "$@" ;;
        exec)              check_container_cli; cmd_exec "$@" ;;
        sync)              check_container_cli; cmd_sync "$@" ;;
        sync-extensions)   check_container_cli; cmd_sync_extensions "$@" ;;
        info)              check_container_cli; cmd_info "$@" ;;
        build)             check_container_cli; cmd_build "$@" ;;
        reset)             check_container_cli; cmd_reset "$@" ;;
        help|--help|-h)    cmd_help ;;
        version|--version|-v) echo "srl-sandbox v${VERSION}" ;;
        -*)                check_container_cli; cmd_launch "$cmd" "$@" ;;
        *)                 check_container_cli; cmd_launch "$cmd" "$@" ;;
    esac
}

main "$@"
