    echo ""
    printf "  ${BOLD}Commands${NC}\n"
    printf "    ${CYAN}launch${NC} ${DIM}[path]${NC}           Create or resume sandbox for project dir ${DIM}(default: cwd)${NC}\n"
    printf "    ${CYAN}stop${NC} ${DIM}<name|all>${NC}         Stop a sandbox\n"
